generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

////////////////////
// ENUMS
////////////////////

enum Role {
  NGO
  COMPANY
  VOLUNTEER
}

enum ProjectStatus {
  DRAFT
  UNDER_REVIEW
  ACTIVE
  COMPLETED
  REJECTED
}

enum ProjectLane {
  PLANNING
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum MilestoneStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum ApplicationStatus {
  APPLIED
  ACCEPTED
  REJECTED
}

////////////////////
// USER (BASE)
////////////////////

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String?
  role          Role
  walletAddress String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ngo       NGOProfile?
  company   CompanyProfile?
  volunteer VolunteerProfile?
}

////////////////////
// NGO
////////////////////

model NGOProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  organization   String
  registrationNo String
  walletAddress  String   @default("")
  phone          String?
  address        String?
  focusAreas     String[]
  description    String?

  user     User      @relation(fields: [userId], references: [id])
  projects Project[]
}

////////////////////
// COMPANY / CSR
////////////////////

model CompanyProfile {
  id            String  @id @default(uuid())
  userId        String  @unique
  companyName   String
  csrRegNo      String
  totalBudget   Float
  walletAddress String  @default("")
  industry      String?
  phone         String?
  address       String?

  user        User            @relation(fields: [userId], references: [id])
  allocations CSRAllocation[]
}

////////////////////
// PROJECT
////////////////////

model Project {
  id            String        @id @default(uuid())
  proposalRef   String        @unique
  title         String
  description   String
  sector        String        // Education, Healthcare, Environment, Rural Dev, Livelihood
  location      String
  budget        Float         @default(0)
  beneficiaries Int           @default(0)
  progress      Int           @default(0) // 0-100
  status        ProjectStatus @default(DRAFT)
  lane          ProjectLane   @default(PLANNING)
  startDate     DateTime?
  endDate       DateTime?
  escrowTxHash  String?
  escrowBalance Float         @default(0)
  ngoId         String
  submittedAt   DateTime?
  createdAt     DateTime      @default(now())

  ngo          NGOProfile            @relation(fields: [ngoId], references: [id])
  milestones   Milestone[]
  allocations  CSRAllocation[]
  applications VolunteerApplication[]
  attendances  Attendance[]
  documents    ProjectDocument[]
}

////////////////////
// PROJECT DOCUMENTS
////////////////////

model ProjectDocument {
  id         String   @id @default(uuid())
  projectId  String
  name       String
  ipfsHash   String
  uploadedAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

////////////////////
// CSR FUND FLOW
////////////////////

model CSRAllocation {
  id           String   @id @default(uuid())
  companyId    String
  projectId    String
  amount       Float
  escrowTxHash String   @default("")
  status       String   @default("PENDING") // PENDING, ACTIVE, RELEASED
  allocatedAt  DateTime @default(now())

  company CompanyProfile @relation(fields: [companyId], references: [id])
  project Project        @relation(fields: [projectId], references: [id])
}

model Milestone {
  id             String          @id @default(uuid())
  milestoneRef   String          @unique
  projectId      String
  title          String
  description    String?
  amount         Float
  deadline       DateTime
  status         MilestoneStatus @default(PENDING)
  proofDesc      String?         // NGO's work description on submission
  proofIpfsHash  String?         // IPFS hash of full proof bundle
  proofPhotoHash String?         // IPFS hash of photo evidence
  geoLocation    String?         // Geo-coordinates
  approvalTx     String?         // On-chain tx hash when approved
  submittedAt    DateTime?
  createdAt      DateTime        @default(now())

  project     Project      @relation(fields: [projectId], references: [id])
  fundRelease FundRelease?
}

model FundRelease {
  id            String   @id @default(uuid())
  milestoneId   String   @unique
  releaseTxHash String
  releasedAt    DateTime @default(now())

  milestone Milestone @relation(fields: [milestoneId], references: [id])
}

////////////////////
// VOLUNTEER
////////////////////

model VolunteerProfile {
  id           String  @id @default(uuid())
  userId       String  @unique
  skills       String[]
  totalHours   Float   @default(0)
  location     String?
  availability String?

  user         User                   @relation(fields: [userId], references: [id])
  applications VolunteerApplication[]
  attendances  Attendance[]
  certificates Certificate[]
}

model VolunteerApplication {
  id          String            @id @default(uuid())
  volunteerId String
  projectId   String
  status      ApplicationStatus @default(APPLIED)
  appliedAt   DateTime          @default(now())

  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id])
  project   Project          @relation(fields: [projectId], references: [id])
}

model Attendance {
  id           String    @id @default(uuid())
  volunteerId  String
  projectId    String
  checkInTime  DateTime
  checkOutTime DateTime?
  hours        Float     @default(0)
  geoHash      String    @default("")
  blockchainTx String?

  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id])
  project   Project          @relation(fields: [projectId], references: [id])
}

model Certificate {
  id           String   @id @default(uuid())
  volunteerId  String
  projectId    String
  title        String
  hours        Float
  ipfsHash     String   @default("")
  blockchainTx String   @default("")
  issuedAt     DateTime @default(now())

  volunteer VolunteerProfile @relation(fields: [volunteerId], references: [id])
}
